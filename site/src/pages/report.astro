                        <td data-label="MAP@R" class="numeric">{fmtMetricPercent(row.mapAtR)}</td>
                        <td data-label="Recall@1" class="numeric">{fmtMetricPercent(row.recallAt1)}</td>
                        <td data-label="ResNet R@1 target" class="numeric">{fmtPublishedPercent(target?.recallAt1Percent)}</td>
                        {endToEndHasInterference && (
                          <td data-label="Interference ρ" class="numeric">
                            {row.interference ? (
                              <>
                                {fmtRho(row.interference.rho_mean)} / {fmtRho(row.interference.rho_p90)}
                                <small> · {fmtFraction(row.interference.fraction_above_floor_002)} &gt; .02</small>
                              </>
                            ) : (
                              "n/a"
                            )}
                          </td>
                        )}
                        <td data-label="Status">
                          {beatsTarget ? <em class="row-badge best">Beats target</em> : <em class="row-badge worst">Below target</em>}
                        </td>
                      </tr>
                    );
                  })
                )}
              </tbody>
            </table>
          </div>
        </div>

        <div class="result-matrix published-results">
          <h3>Latest field references for paper-protocol comparison</h3>
          <p>
            {publishedReferences.latestNote} The MAP@R target and Recall@1 context
            are kept separate so we do not compare against metrics or architectures
            that the cited paper did not report in the same setup.
          </p>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Dataset</th>
                  <th>Method</th>
                  <th>Venue</th>
                  <th>Backbone</th>
                  <th class="numeric">MAP@R</th>
                  <th class="numeric">Recall@1</th>
                  <th>Source</th>
                </tr>
              </thead>
              <tbody>
                {latestFieldRows.map((row) => (
                  <tr data-kind={row.comparisonScope === "same_architecture_target" ? "best" : "normal"}>
                    <td data-label="Dataset"><b>{row.dataset}</b></td>
                    <td data-label="Method">
                      <div class="method-cell">
                        <b>{row.method}</b>
                        <span>
                          {row.method === "PFML" && <em class="row-badge best">Peer-reviewed target</em>}
                          {row.method === "CouCE" && <em class="row-badge context">Training-module context</em>}
                          {row.method === "SGSL" && <em class="row-badge best">Recall@1 ceiling</em>}
                        </span>
                      </div>
                    </td>
                    <td data-label="Venue">{row.venue}</td>
                    <td data-label="Backbone">{row.backbone}</td>
                    <td data-label="MAP@R" class="numeric">{fmtPublishedPercent(row.mapAtRPercent)}</td>
                    <td data-label="Recall@1" class="numeric">{fmtPublishedPercent(row.recallAt1Percent)}</td>
                    <td data-label="Source">
                      <a href={row.url} target="_blank" rel="noreferrer">{row.source}</a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        {historicalRecallRows.length > 0 && (
          <div class="result-matrix published-results">
            <h3>Historical Recall@1 context that is not the ResNet target</h3>
            <p>{publishedReferences.historicalRecallNote}</p>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Dataset</th>
                    <th>Method</th>
                    <th>Venue</th>
                    <th>Backbone</th>
                    <th class="numeric">Recall@1</th>
                    <th>Why excluded from target</th>
                    <th>Source</th>
                  </tr>
                </thead>
                <tbody>
                  {historicalRecallRows.map((row) => (
                    <tr>
                      <td data-label="Dataset"><b>{row.dataset}</b></td>
                      <td data-label="Method">
                        <div class="method-cell">
                          <b>{row.method}</b>
                          <span><em class="row-badge ours">Context only</em></span>
                        </div>
                      </td>
                      <td data-label="Venue">{row.venue}</td>
                      <td data-label="Backbone">{row.backbone}</td>
                      <td data-label="Recall@1" class="numeric">
                        {fmtPublishedPercent(row.recallAt1Percent)}
                      </td>
                      <td data-label="Why excluded">{row.note}</td>
                      <td data-label="Source">
                        <a href={row.url} target="_blank" rel="noreferrer">{row.source}</a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {noisyLabelBaselineRows.length > 0 && (
          <div class="result-matrix published-results">
            <h3>PFML noisy-label ResNet baseline context</h3>
            <p>{publishedReferences.noisyLabelBaselineNote}</p>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Dataset</th>
                    <th>Method</th>
                    <th>Venue</th>
                    <th>Backbone</th>
                    <th class="numeric">Recall@1</th>
                    <th>Scope</th>
                    <th>Source</th>
                  </tr>
                </thead>
                <tbody>
                  {noisyLabelBaselineRows.map((row) => (
                    <tr data-kind={row.method === "PFML" ? "best" : "normal"}>
                      <td data-label="Dataset"><b>{row.dataset}</b></td>
                      <td data-label="Method">
                        <div class="method-cell">
                          <b>{row.method}</b>
                          <span>
                            {row.method === "Triplet" && <em class="row-badge ours">Triplet sanity context</em>}
                            {row.method === "PFML" && <em class="row-badge best">Noisy-label PFML</em>}
                          </span>
                        </div>
                      </td>
                      <td data-label="Venue">{row.venue}</td>
                      <td data-label="Backbone">{row.backbone}</td>
                      <td data-label="Recall@1" class="numeric">
                        {fmtPublishedPercent(row.recallAt1Percent)}
                      </td>
                      <td data-label="Scope">{row.note}</td>
                      <td data-label="Source">
                        <a href={row.url} target="_blank" rel="noreferrer">{row.source}</a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        <div class="result-matrix published-results">
          <h3>Historical 2022 MAP@R, P@1, and R-Precision references</h3>
          <p>
            Values are percentages copied into structured data from the cited paper
            tables. Green rows are the best MAP@R HPL-era row for each dataset.
            These rows use the standardized BN-Inception 4-fold concatenated protocol,
            so they are context rather than the same-ResNet target.
          </p>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Dataset</th>
                  <th>Method</th>
                  <th>Paper protocol</th>
                  <th class="numeric">MAP@R</th>
                  <th class="numeric">P@1</th>
                  <th class="numeric">R-Precision</th>
                  <th>Source</th>
                </tr>
              </thead>
              <tbody>
                {publishedRows.map((row) => {
                  const isBest = publishedBestKeys.has(`${row.dataset}:${row.method}`);
                  return (
                    <tr data-kind={isBest ? "best" : "normal"}>
                      <td data-label="Dataset"><b>{row.dataset}</b></td>
                      <td data-label="Method">
                        <div class="method-cell">
                          <b>{row.method}</b>
                          <span>{isBest && <em class="row-badge best">Best paper row</em>}</span>
                        </div>
                      </td>
                      <td data-label="Paper protocol">{row.protocol}</td>
                      <td data-label="MAP@R" class="numeric">{fmtPublishedPercent(row.mapAtRPercent)}</td>
                      <td data-label="P@1" class="numeric">{fmtPublishedPercent(row.pAt1Percent)}</td>
                      <td data-label="R-Precision" class="numeric">{fmtPublishedPercent(row.rPrecisionPercent)}</td>
                      <td data-label="Source">
                        <a href={row.url} target="_blank" rel="noreferrer">{row.source} {row.table}</a>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>

        <div class="result-matrix published-results">
          <h3>Original Proxy Anchor paper Recall@1 reference</h3>
          <p>
            These rows keep the original Proxy Anchor paper's Recall@K reporting
            separate from the HPL MAP@R table and from our controlled MAP@R study.
          </p>
          <div class="table-wrap compact-reference-table">
            <table>
              <thead>
                <tr>
                  <th>Dataset</th>
                  <th>Method</th>
                  <th class="numeric">Recall@1</th>
                  <th>Source</th>
                </tr>
              </thead>
              <tbody>
                {proxyAnchorRecallRows.map((row) => (
                  <tr>
                    <td data-label="Dataset"><b>{row.dataset}</b></td>
                    <td data-label="Method">{row.method}</td>
                    <td data-label="Recall@1" class="numeric">{fmtPublishedPercent(row.recallAt1Percent)}</td>
                    <td data-label="Source">
                      <a href={row.url} target="_blank" rel="noreferrer">{row.source} {row.table}</a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="section" id="interpretation">
        <p class="section-label">Interpretation</p>
        <h2>Evidence-backed interpretation</h2>
        <p>
          The conclusion is split into claim, caveat, and effect size so the report
          does not overstate one loss component or hide the role of XBM and radius
          regularization.
        </p>
        <div class="evidence-tabs" data-evidence-tabs="true">
          <div class="tab-row">
            {evidencePanels.map((panel, index) => (
              <button
                type="button"
                data-evidence-tab={panel.key}
                data-active={index === 0 ? "true" : "false"}
              >
                {panel.title}
              </button>
            ))}
          </div>
          {evidencePanels.map((panel, index) => (
            <article class="evidence-panel" data-evidence-panel={panel.key} hidden={index !== 0}>
              <div class="evidence-number">
                <b>{panel.metric}</b>
                <span>{panel.label}</span>
              </div>
              <div class="evidence-copy">
                <h3>{panel.title}</h3>
                <p>{panel.text}</p>
              </div>
            </article>
          ))}
        </div>
        <div class="interpretation">
          <p>
            Final reading: the proposed method is <b>Group SupCon + XBM + Radius</b>.
            The measured gains come from the complete recipe: point-level contrast,
            group-level contrast, memory-backed comparisons, and radius control.
          </p>
        </div>
        <div class="limits-panel" aria-label="Limitations and reading rules">
          <div>
            <p class="section-label">Limits</p>
            <h3>How to read the evidence</h3>
          </div>
          <div class="limits-grid">
            {limitationCards.map((card) => (
              <article>
                <h4>{card.title}</h4>
                <p>{card.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section" id="appendix">
        <p class="section-label">Appendix</p>
        <h2>Full interactive image-result appendix</h2>
        <p>
          Use filters and sorting to inspect all datasets, backbones, and objectives.
          Badges mark best, proposed, and worst rows. Green values improve over the
          frozen baseline; red values regress. The chart and table use the same
          controls so readers can first scan the pattern and then inspect exact
          values.
        </p>
        <div class="filter-row">
          <label>Dataset
            <select data-filter="dataset">
              <option value="all">All datasets</option>
              {datasets.map((dataset) => <option value={dataset}>{dataset}</option>)}
            </select>
          </label>
          <label>Method
            <select data-filter="method">
              <option value="all">All methods</option>
              {methods.map((method) => <option value={method}>{method}</option>)}
            </select>
          </label>
          <label>Backbone
            <select data-filter="model">
              <option value="all">All backbones</option>
              {models.map((model) => <option value={model}>{model}</option>)}
            </select>
          </label>
        </div>
        <div class="sort-row">
          <button type="button" data-sort="map" data-active="true">Sort by MAP@R delta</button>
          <button type="button" data-sort="recall">Sort by Recall@1 delta</button>
          <button type="button" data-sort="name">Sort by method name</button>
          <button type="button" data-sort="best">Best and ours first</button>
          <button type="button" data-sort="reset">Reset</button>
        </div>
        <p class="appendix-status" aria-live="polite">
          <b data-visible-count>{sortedRows.length}</b> of <b data-total-count>{sortedRows.length}</b>
          rows shown. Filters update the chart and the table together.
        </p>
        <p class="empty-state" data-empty-state hidden>No rows match the current filters.</p>

        <div class="chart-panel" data-chart>
          <div class="chart-heading">
            <div>
              <h3>MAP@R delta by dataset, backbone, and method</h3>
              <p>
                The chart shows the top rows under the active sort so the pattern is
                readable. The table below remains the full appendix.
              </p>
            </div>
            <button type="button" data-chart-toggle>Show all chart rows</button>
          </div>
          {sortedRows.map((row: ImageRow) => (
            <div
              class="chart-row"
              data-row
              data-result-row
              data-view="chart"
              data-dataset={row.dataset}
              data-method={row.methodName}
              data-model={row.modelName}
              data-map={row.mapAtRDelta ?? 0}
              data-recall={row.recallAt1Delta ?? 0}
              data-ours={row.isOurs ? "true" : "false"}
              data-kind={row.resultKind}
              data-sign={(row.mapAtRDelta ?? 0) < 0 ? "negative" : "positive"}
            >
              <div class="chart-label">
                <b>
                  {row.methodName}
                  {row.resultKind === "best" && <em class="row-badge best">Best</em>}
                  {row.isOurs && <em class="row-badge ours">Proposed</em>}
                  {row.resultKind === "worst" && <em class="row-badge worst">Worst</em>}
                </b>
                <span>{row.dataset} · {row.modelName}</span>
              </div>
              <div class="chart-track"><i style={`--w:${((Math.abs(row.mapAtRDelta ?? 0) / maxDelta) * 100).toFixed(1)}%`}></i></div>
              <div class="chart-value" data-sign={(row.mapAtRDelta ?? 0) < 0 ? "negative" : "positive"}>
                {fmtDelta(row.mapAtRDelta)}
              </div>
            </div>
          ))}
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Dataset</th>
                <th><button type="button" data-sort="name">Method</button></th>
                <th>Backbone</th>
                <th class="numeric">MAP@R</th>
                <th class="numeric"><button type="button" data-sort="map">MAP@R delta</button></th>
                <th class="numeric"><button type="button" data-sort="recall">Recall@1 delta</button></th>
              </tr>
            </thead>
            <tbody>
              {sortedRows.map((row: ImageRow) => (
                <tr
                  data-row
                  data-result-row
                  data-view="table"
                  data-dataset={row.dataset}
                  data-method={row.methodName}
                  data-model={row.modelName}
                  data-map={row.mapAtRDelta ?? 0}
                  data-recall={row.recallAt1Delta ?? 0}
                  data-ours={row.isOurs ? "true" : "false"}
                  data-kind={row.resultKind}
                  data-sign={(row.mapAtRDelta ?? 0) < 0 ? "negative" : "positive"}
                >
                  <td>{row.dataset}</td>
                  <td>
                    <div class="method-cell">
                      <b>{row.methodName}</b>
                      <span>
                        {row.resultKind === "best" && <em class="row-badge best">Best</em>}
                        {row.isOurs && <em class="row-badge ours">Proposed</em>}
                        {row.resultKind === "worst" && <em class="row-badge worst">Worst</em>}
                      </span>
                    </div>
                  </td>
                  <td>{row.modelName}</td>
                  <td class="numeric">{fmt(row.mapAtR)}</td>
                  <td class="numeric delta-cell" data-sign={(row.mapAtRDelta ?? 0) < 0 ? "negative" : "positive"}>
                    {fmtDelta(row.mapAtRDelta)}
                  </td>
                  <td class="numeric">{fmtDelta(row.recallAt1Delta)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </main>

    <script>
      const activateTabs = (tabSelector, panelSelector, keyName) => {
        const tabs = Array.from(document.querySelectorAll(tabSelector));
        const panels = Array.from(document.querySelectorAll(panelSelector));
        tabs.forEach((tab) => {
          tab.setAttribute("aria-pressed", tab.dataset.active === "true" ? "true" : "false");
        });
        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const key = tab.dataset[keyName];
            tabs.forEach((item) => {
              item.dataset.active = String(item === tab);
              item.setAttribute("aria-pressed", item === tab ? "true" : "false");
            });
            panels.forEach((panel) => {
              panel.hidden = panel.dataset[keyName.replace("Tab", "Panel")] !== key;
            });
          });
        });
      };

      activateTabs("[data-anatomy-tab]", "[data-anatomy-panel]", "anatomyTab");
      activateTabs("[data-architecture-tab]", "[data-architecture-panel]", "architectureTab");
      activateTabs("[data-equation-tab]", "[data-equation-panel]", "equationTab");
      activateTabs("[data-lift-tab]", "[data-lift-panel]", "liftTab");
      activateTabs("[data-comparison-tab]", "[data-comparison-panel]", "comparisonTab");
      activateTabs("[data-evidence-tab]", "[data-evidence-panel]", "evidenceTab");

      const filters = {
        dataset: document.querySelector('[data-filter="dataset"]'),
        method: document.querySelector('[data-filter="method"]'),
        model: document.querySelector('[data-filter="model"]'),
      };
      const rows = Array.from(document.querySelectorAll("[data-result-row]"));
      const tableRows = rows.filter((row) => row.dataset.view === "table");
      const sortButtons = Array.from(document.querySelectorAll("[data-sort]"));
      const parents = Array.from(new Set(rows.map((row) => row.parentElement).filter(Boolean)));
      const visibleCount = document.querySelector("[data-visible-count]");
      const emptyState = document.querySelector("[data-empty-state]");
      const chartToggle = document.querySelector("[data-chart-toggle]");
      const chartLimit = 36;
      let chartExpanded = false;

      const matches = (row) => {
        return (
          (filters.dataset.value === "all" || row.dataset.dataset === filters.dataset.value) &&
          (filters.method.value === "all" || row.dataset.method === filters.method.value) &&
          (filters.model.value === "all" || row.dataset.model === filters.model.value)
        );
      };

      const rank = (row) => {
        if (row.dataset.kind === "best") return 0;
        if (row.dataset.ours === "true") return 1;
        return 2;
      };

      const applyFilters = () => {
        let visibleTableRows = 0;
        tableRows.forEach((row) => {
          const isVisible = matches(row);
          row.hidden = !isVisible;
          if (isVisible) visibleTableRows += 1;
        });

        const chartRows = Array.from(document.querySelectorAll('[data-result-row][data-view="chart"]'));
        let matchingChartRows = 0;
        chartRows.forEach((row) => {
          const isVisible = matches(row);
          if (isVisible) matchingChartRows += 1;
          row.hidden = !isVisible || (!chartExpanded && matchingChartRows > chartLimit);
        });

        if (chartToggle) {
          chartToggle.hidden = matchingChartRows <= chartLimit;
          chartToggle.textContent = chartExpanded ? "Show fewer chart rows" : "Show all chart rows";
          chartToggle.setAttribute("aria-expanded", chartExpanded ? "true" : "false");
        }
        if (visibleCount) visibleCount.textContent = String(visibleTableRows);
        if (emptyState) emptyState.hidden = visibleTableRows > 0;
      };

      const applySort = (mode) => {
        parents.forEach((parent) => {
          const childRows = rows.filter((row) => row.parentElement === parent);
          const sorted = [...childRows].sort((a, b) => {
            if (mode === "best") return rank(a) - rank(b);
            if (mode === "reset") return childRows.indexOf(a) - childRows.indexOf(b);
            if (mode === "recall") return Number(b.dataset.recall) - Number(a.dataset.recall);
            if (mode === "name") return (a.dataset.method || "").localeCompare(b.dataset.method || "");
            return Number(b.dataset.map) - Number(a.dataset.map);
          });
          parent.append(...sorted);
        });
        sortButtons.forEach((button) => {
          button.dataset.active = String(button.dataset.sort === mode);
          button.setAttribute("aria-pressed", button.dataset.sort === mode ? "true" : "false");
        });
        applyFilters();
      };

      Object.values(filters).forEach((filter) => filter.addEventListener("change", applyFilters));
      sortButtons.forEach((button) => {
        button.addEventListener("click", () => applySort(button.dataset.sort || "map"));
      });
      if (chartToggle) {
        chartToggle.setAttribute("aria-expanded", "false");
        chartToggle.addEventListener("click", () => {
          chartExpanded = !chartExpanded;
          applyFilters();
        });
      }
      sortButtons.forEach((button) => {
        button.setAttribute("aria-pressed", button.dataset.active === "true" ? "true" : "false");
      });
      applyFilters();
    </script>
  </body>
</html>
