                    <td>{method.mechanism}</td>
                    <td>{method.role}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="section" id="comparison">
        <p class="section-label">Method comparison</p>
        <h2>SupCon baseline, Group SupCon core, and full recipe</h2>
        <p>
          Supervised Contrastive (SupCon) is the external same-backbone reference.
          Group SupCon is our standard point+group core method. Group SupCon + XBM
          + Radius is the complete proposed method measured against the previous
          same-backbone result. Values in this ladder are actual MAP@R, not MAP@R
          deltas.
        </p>
        <div class="supcon-comparison" data-supcon-comparison="true">
          <div class="tab-row">
            {supconComparisons.map((comparison, index) => (
              <button
                type="button"
                data-comparison-tab={comparison.datasetKey}
                data-active={index === 0 ? "true" : "false"}
