                {comparison.dataset}
              </button>
            ))}
          </div>
          {supconComparisons.map((comparison, index) => (
            <article
              class="comparison-panel"
              data-comparison-panel={comparison.datasetKey}
              hidden={index !== 0}
            >
              <div class="comparison-copy">
                <h3>{comparison.dataset}</h3>
                <p>
                  Read this as a method ladder: point-only contrast, then point+group
                  contrast, then the full recipe with memory-backed negatives and
                  radius control. The Group SupCon core is an ablation and can trail
                  SupCon; the claim is the full recipe.
