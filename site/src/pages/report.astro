---
import report from "../data/report-data.json";
import "../styles/report.css";

type ImageRow = {
  dataset: string;
  datasetKey: string;
  modelName: string;
  methodName: string;
  objective?: string | null;
  artifact?: string | null;
  variantLabel?: string | null;
  recallAt1?: number | null;
  mapAtR: number | null;
  mapAtRDelta: number | null;
  recallAt1Delta: number | null;
  resultKind: string;
  isOurs: boolean;
  interference?: Record<string, number> | null;
};

type SupconComparison = {
  dataset: string;
  datasetKey: string;
  supcon: ImageRow;
  groupSupcon: ImageRow;
  fullRecipe: ImageRow;
  groupAdvantage: number | null;
  fullAdvantage: number | null;
};

type ProtocolDataset = {
  dataset: string;
  examples: number | null;
  trainExamples: number | null;
  testExamples: number | null;
  evaluatedQueries: number | null;
  totalQueries: number | null;
};

type PublishedReferenceRow = {
  dataset: string;
  method: string;
  mapAtRPercent?: number | null;
  pAt1Percent?: number | null;
  rPrecisionPercent?: number | null;
  recallAt1Percent?: number | null;
  source: string;
  table: string;
  url: string;
  protocol?: string;
};

const imageRows = (report.imageRows ?? []) as ImageRow[];
const endToEndRows = (report.endToEndRows ?? []) as ImageRow[];
const mainResults = (report.mainResults ?? []) as Array<ImageRow & Record<string, any>>;
const references = (report.references ?? []) as Array<Record<string, string>>;
const methodCatalog = (report.methodCatalog ?? []) as Array<Record<string, any>>;
const supconComparisons = (report.supconComparisons ?? []) as SupconComparison[];
const publishedReferences = (report.publishedReferences ?? {}) as Record<string, any>;
const publishedRows = (publishedReferences.rows ?? []) as PublishedReferenceRow[];
const publishedBestRows = (publishedReferences.bestRows ?? []) as PublishedReferenceRow[];
const latestFieldRows = (publishedReferences.latestRows ?? []) as Array<
  PublishedReferenceRow & { venue: string; backbone: string; comparisonScope?: string }
>;
const historicalRecallRows = (publishedReferences.historicalRecallRows ?? []) as Array<
  PublishedReferenceRow & {
    venue: string;
    backbone: string;
    comparisonScope?: string;
    note?: string;
  }
>;
const noisyLabelBaselineRows = (publishedReferences.noisyLabelBaselineRows ?? []) as Array<
  PublishedReferenceRow & {
    venue: string;
    backbone: string;
    comparisonScope?: string;
    note?: string;
  }
>;
const primaryMapRows = (publishedReferences.primaryMapRows ?? []) as Array<
  PublishedReferenceRow & { venue: string; backbone: string; comparisonScope?: string }
>;
const primaryResnetRecallRows = (publishedReferences.primaryResnetRecallRows ?? []) as Array<
  PublishedReferenceRow & { venue: string; backbone: string; comparisonScope?: string }
>;
const proxyAnchorRecallRows = (publishedReferences.proxyAnchorRecall ?? []) as PublishedReferenceRow[];
const protocol = report.protocol ?? {};
const findings = report.findings ?? {};
const protocolDatasets = (protocol.datasets ?? []) as ProtocolDataset[];
const protocolMetrics = (protocol.metrics ?? []) as Array<Record<string, string>>;
const fmt = (value: number | null | undefined, digits = 4) =>
  value === null || value === undefined ? "n/a" : value.toFixed(digits);
const fmtCount = (value: number | null | undefined) =>
  value === null || value === undefined ? "n/a" : Math.round(value).toLocaleString("en-US");
const fmtDelta = (value: number | null | undefined) =>
  value === null || value === undefined ? "n/a" : `${value >= 0 ? "+" : ""}${value.toFixed(4)}`;
const fmtPercent = (value: number | null | undefined) =>
  value === null || value === undefined ? "n/a" : `${value >= 0 ? "+" : ""}${(value * 100).toFixed(1)}%`;
const fmtPublishedPercent = (value: number | null | undefined) =>
  value === null || value === undefined ? "n/a" : `${value.toFixed(2)}%`;
const fmtMetricPercent = (value: number | null | undefined) =>
  value === null || value === undefined ? "n/a" : `${(value * 100).toFixed(2)}%`;
const fmtRho = (value: number | null | undefined) =>
  value === null || value === undefined ? "n/a" : value.toFixed(3);
const fmtFraction = (value: number | null | undefined) =>
  value === null || value === undefined ? "n/a" : `${(value * 100).toFixed(0)}%`;
const endToEndHasInterference = endToEndRows.some((row) => row.interference);
const datasets = Array.from(new Set(imageRows.map((row: ImageRow) => row.dataset)));
const methods = Array.from(new Set(imageRows.map((row: ImageRow) => row.methodName))).sort();
const models = Array.from(new Set(imageRows.map((row: ImageRow) => row.modelName))).sort();
const maxDelta = Math.max(
  0.001,
  ...imageRows.map((row: ImageRow) => Math.abs(row.mapAtRDelta ?? 0)),
);
const sortedRows = [...imageRows].sort(
  (left: ImageRow, right: ImageRow) => (right.mapAtRDelta ?? -999) - (left.mapAtRDelta ?? -999),
);
const publishedBestKeys = new Set(
  publishedBestRows.map((row) => `${row.dataset}:${row.method}`),
);
const controlledDatasetName = (dataset: string) =>
  dataset === "SOP" ? "Stanford Online Products" : dataset;
const controlledResultForPublishedDataset = (dataset: string) =>
  mainResults.find((row) => row.dataset === controlledDatasetName(dataset));
const latestCeilingForDataset = (dataset: string) =>
  primaryMapRows.find((row) => row.dataset === dataset);
const resnetRecallTargetForDataset = (dataset: string) =>
  primaryResnetRecallRows.find((row) => row.dataset === dataset);
const proposedEndToEndResultForPublishedDataset = (dataset: string) =>
  endToEndRows
    .filter(
      (row) =>
        row.dataset === controlledDatasetName(dataset) &&
        row.objective === "group_supcon_xbm_radius",
    )
    .sort((left, right) => (right.recallAt1 ?? -1) - (left.recallAt1 ?? -1))[0];
const supconEndToEndResultForPublishedDataset = (dataset: string) =>
  endToEndRows.find(
    (row) => row.dataset === controlledDatasetName(dataset) && row.objective === "supcon",
  );
const maxResultGain = Math.max(
  0.001,
  ...mainResults.map((row) => Math.abs(row.priorResultGain ?? 0)),
);
const totalImages = protocolDatasets.reduce((sum, dataset) => sum + (dataset.examples ?? 0), 0);
const totalQueries = protocolDatasets.reduce(
  (sum, dataset) => sum + (dataset.evaluatedQueries ?? 0),
  0,
);
const heroSummaryItems = [
  {
    label: "Image datasets",
    value: String(report.summary.imageDatasetCount ?? datasets.length),
    detail: `${fmtCount(totalImages)} images`,
  },
  { label: "Held-out queries", value: fmtCount(totalQueries) },
  { label: "Wins vs prior", value: `${findings.priorWins ?? 0}/${findings.datasetCount ?? 0}` },
  {
    label: "Best result gain",
    value: fmtPercent(findings.bestResultGain),
    detail: findings.bestResultGainDataset ?? "",
  },
];
const researchAnswerItems = [
  {
    title: "Research question",
    text:
      "Can group-aware supervision improve retrieval when we isolate the method in a simple frozen-backbone head experiment, and then when we reproduce paper-style ResNet-50 training?",
  },
  {
    title: "Proposed answer",
    text:
      "Use point SupCon plus same-class group centroids, then add cross-batch memory and radius control so groups stay discriminative and compact.",
  },
  {
    title: "Evidence standard",
    text:
      "Judge the power experiment with same-backbone MAP@R and Recall@1; judge the paper-protocol claim only with end-to-end ResNet-50/512 results.",
  },
  {
    title: "Current result",
    text: `${report.claim.bestMethod} wins ${findings.priorWins ?? 0}/${findings.datasetCount ?? 0} image datasets with a mean result gain of ${fmtPercent(findings.meanResultGain)}.`,
  },
];
const architecturePanels = [
  {
    key: "group",
    title: "Same-class groups",
    summary: "Group SupCon keeps point SupCon and adds a same-class centroid term.",
    detail:
      "The representative is a normalized group centroid. This preserves point-level positives while adding centroid movement and within-group structure before retrieval is evaluated.",
  },
  {
    key: "xbm",
    title: "Memory-backed negatives",
    summary: "XBM extends the comparison pool beyond the current mini-batch.",
    detail:
      "Recent embeddings remain available as negatives. That makes the denominator harder and reduces the chance that a batch looks easy only because it missed confusing classes.",
  },
  {
    key: "radius",
    title: "Radius-controlled neighborhoods",
    summary: "Radius regularization constrains how much each class-local group can spread.",
    detail:
      "The head should improve ranking without creating brittle neighborhoods that are hard to reuse in downstream tasks.",
  },
];
const methodAnatomySteps = [
  {
    key: "encoder",
    label: "Frozen image encoder",
    detail: "Base model stays fixed",
  },
  {
    key: "point",
    label: "Point SupCon",
    detail: "same-class examples",
  },
  {
    key: "group",
    label: "Group centroids",
    detail: "same-class representatives",
  },
  {
    key: "xbm",
    label: "XBM memory",
    detail: "harder negatives",
  },
  {
    key: "radius",
    label: "Radius control",
    detail: "compact neighborhoods",
  },
  {
    key: "retrieval",
    label: "Held-out retrieval",
    detail: "MAP@R and Recall@1",
  },
];
const methodAnatomyPanels = [
  {
    key: "supcon",
    title: "Supervised Contrastive (SupCon)",
    badge: "external baseline",
    summary:
      "Only individual examples define the contrastive signal. This is the strongest point-level baseline.",
    enabledStepKeys: ["encoder", "point", "retrieval"],
    reading:
      "Useful baseline, but it has no explicit group representative, memory queue, or radius pressure.",
  },
  {
    key: "group",
    title: "Group SupCon",
    badge: "proposed core",
    summary:
      "Keeps point SupCon and adds a supervised contrastive term over normalized same-class group centroids.",
    enabledStepKeys: ["encoder", "point", "group", "retrieval"],
    reading:
      "This is the standard group-aware method: point-level SupCon plus the group-centroid contrastive term.",
  },
  {
    key: "xbm",
    title: "Group SupCon + XBM",
    badge: "proposed memory",
    summary:
      "Adds recent embeddings to the comparison pool so training sees harder negatives than one mini-batch provides.",
    enabledStepKeys: ["encoder", "point", "group", "xbm", "retrieval"],
    reading:
      "This tests whether the group signal becomes more useful when the denominator contains stronger confusions.",
  },
  {
    key: "full",
    title: "Group SupCon + XBM + Radius",
    badge: "main method",
    summary:
      "Combines point SupCon, group centroids, memory-backed negatives, and radius control in one projection-head objective.",
    enabledStepKeys: ["encoder", "point", "group", "xbm", "radius", "retrieval"],
    reading:
      "This is the method claimed in the headline and compared against the best same-backbone prior.",
  },
];
const equationPanels = [
  {
    key: "supcon",
    title: "SupCon point loss",
    unit: "individual examples",
    explanation:
      "Supervised Contrastive (SupCon) treats each example as the anchor and averages over same-class positive examples.",
  },
  {
    key: "group",
    title: "Group SupCon equation",
    unit: "individual examples plus same-class groups",
    explanation:
      "Group SupCon keeps the point-level SupCon term and adds a supervised contrastive term over normalized group centroids.",
  },
  {
    key: "full",
    title: "Full proposed recipe",
    unit: "groups plus memory and radius",
    explanation:
      "The final method keeps point plus group SupCon, adds XBM hard-negative memory, and penalizes excessive group radius.",
  },
];
const evidencePanels = [
  {
    key: "claim",
    title: "Main claim",
    metric: `${findings.priorWins ?? 0}/${findings.datasetCount ?? 0}`,
    label: "datasets beat prior",
    text:
      "The full proposed recipe beats the best same-backbone non-proposed method on the image datasets reported here.",
  },
  {
    key: "caveat",
    title: "Method hierarchy",
    metric: "Core",
    label: "point plus group contrast",
    text:
      "Group SupCon is the proposed core method: point SupCon plus normalized group-centroid contrast. The main recipe adds XBM and radius control on top.",
  },
  {
    key: "effect",
    title: "Effect size",
    metric: fmtPercent(findings.bestResultGain),
    label: `best result gain (${findings.bestResultGainDataset ?? "n/a"})`,
    text:
      "The percentage is computed from actual MAP@R results against the previous same-backbone method, so it reads as a direct result lift.",
  },
];
const limitationCards = [
  {
    title: "Primary evidence",
    text:
      "The claim is based on held-out image retrieval: MAP@R, Recall@1, and result gain against the best same-backbone prior.",
  },
  {
    title: "What is not compared",
    text:
      "Objective losses are not used as cross-method evidence because each method optimizes a different loss surface.",
  },
  {
    title: "Scope of the claim",
    text:
      "The current validated claim covers frozen image encoders with projection-head training. The paper-level claim is pending ResNet-50/512 end-to-end results.",
  },
];
const methodMatrix = [
  {
    name: "Frozen encoder",
    origin: "External baseline",
    unit: "image embedding",
    mechanism: "No projection training; retrieval is measured directly on the pretrained backbone.",
    role: "Controls for backbone quality.",
    citation: "",
    href: "",
    isOurs: false,
  },
  {
    name: "Triplet / Batch-Hard Triplet",
    origin: "External",
    unit: "anchor-positive-negative points",
    mechanism: "Pulls a positive point closer than a negative point, optionally using hard in-batch examples.",
    role: "Point-level metric-learning baseline.",
    citation: "FaceNet",
    href: "https://arxiv.org/abs/1503.03832",
    isOurs: false,
  },
  {
    name: "Supervised Contrastive (SupCon)",
    origin: "External",
    unit: "individual examples",
    mechanism: "Treats every same-class example as a positive for a point anchor.",
    role: "Strong point-level contrastive baseline.",
    citation: "Khosla et al.",
    href: "https://arxiv.org/abs/2004.11362",
    isOurs: false,
  },
  {
    name: "Proxy and margin-softmax losses",
    origin: "External",
    unit: "points and class proxies",
    mechanism: "Optimizes against class representatives or angular margins instead of sampled groups.",
    role: "Published metric-learning family.",
    citation: "Proxy-NCA",
    href: "https://arxiv.org/abs/1703.07464",
    isOurs: false,
  },
  {
    name: "Group SupCon",
    origin: "Proposed",
    unit: "same-class centroids",
    mechanism:
      "Keeps point-level SupCon, then builds normalized group centroids and contrasts those group representatives.",
    role: "Tests the core group-representation idea.",
    citation: "",
    href: "",
    isOurs: true,
  },
  {
    name: "Hybrid",
    origin: "Proposed",
    unit: "points plus groups",
    mechanism: "Combines point-level pressure with group-level structure so the head does not optimize centroids only.",
    role: "Bridge between standard metric learning and group learning.",
    citation: "",
    href: "",
    isOurs: true,
  },
  {
    name: "Hybrid + XBM",
    origin: "Proposed",
    unit: "points, groups, memory",
    mechanism: "Adds cross-batch memory so negatives are not limited to the current mini-batch.",
    role: "Tests hard-negative coverage.",
    citation: "XBM",
    href: "https://arxiv.org/abs/1912.06798",
    isOurs: true,
  },
  {
    name: "Hybrid + Radius",
    origin: "Proposed",
    unit: "points, groups, radius",
    mechanism: "Adds a radius penalty to keep class-local neighborhoods compact.",
    role: "Tests whether compactness improves retrieval reuse.",
    citation: "",
    href: "",
    isOurs: true,
  },
  {
    name: "Group SupCon + XBM + Radius",
    origin: "Proposed main method",
    unit: "groups, memory, radius",
    mechanism: "Uses group centroids, memory-backed comparisons, and radius control in one objective.",
    role: "Main claim evaluated in the result cards.",
    citation: "",
    href: "",
    isOurs: true,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{report.title}</title>
  </head>
  <body>
    <main class="shell" data-report-page>
      <header class="hero">
        <p class="kicker">Image Retrieval Research Report</p>
        <h1>{report.claim.headline}</h1>
        <p class="hero-copy">{report.claim.detail}</p>
        <dl class="summary-strip">
          {heroSummaryItems.map((item) => (
            <div>
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
              {item.detail && <p>{item.detail}</p>}
            </div>
          ))}
        </dl>
      </header>

      <nav class="toc" aria-label="Report sections">
        <a href="#abstract">Abstract</a>
        <a href="#state">Background</a>
        <a href="#protocol">Protocol</a>
        <a href="#proposal">Proposal</a>
        <a href="#comparison">Ablation</a>
        <a href="#results">Results</a>
        <a href="#published">Published refs</a>
        <a href="#interpretation">Interpretation</a>
        <a href="#appendix">Appendix</a>
      </nav>

      <section class="section" id="abstract">
        <p class="section-label">Abstract</p>
        <h2>Two-track evidence: method power, then paper protocol</h2>
        <p>
          This report separates the evidence into two tracks. The first track is a
          method-power study: keep DINOv2, CLIP, and SigLIP frozen, train only a
          lightweight head, and ask whether <b>Group SupCon + XBM + Radius</b> improves
          retrieval over the same backbone. The second track reproduces the paper
          scenario with end-to-end <b>ResNet-50 / 512-dim</b> training.
        </p>
        <p>
          IMDb transfer results remain secondary: they explain why cleaner embedding
          spaces can support smaller downstream classifiers, but the proposed method
          is judged first on image retrieval datasets.
        </p>
        <div class="research-answer" aria-label="Research answer summary">
          {researchAnswerItems.map((item) => (
            <article>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="state">
        <p class="section-label">Context</p>
        <h2>What existing metric learning misses</h2>
        <p class="lede">
          Standard triplet, SupCon, proxy, and margin-softmax losses mostly compare
          individual examples or class proxies. The missing piece is an objective that
          exposes group centroids, hard members, memory-backed negatives, and
          within-group radius at the same time.
        </p>
        <ul class="reference-list">
          {references.map((reference) => (
            <li>
              <a href={reference.url} target="_blank" rel="noreferrer">{reference.title}</a>
              <span>{reference.description}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="section" id="protocol">
        <p class="section-label">Experimental protocol</p>
        <h2>Same-backbone image retrieval evaluation</h2>
        <p>
          This section is the method-power protocol only. Each dataset is split into
          train and held-out test examples. Projection heads are trained on frozen
          DINOv2, CLIP, and SigLIP features, then evaluated against the same backbone.
          These backbones are not used for the paper-protocol claim.
        </p>

        <div class="protocol-flow" aria-label="Experimental protocol flow">
          <article>
            <span>1</span>
            <h3>Dataset split</h3>
            <p>Train examples fit the projection head; held-out test examples define retrieval queries.</p>
          </article>
          <article>
            <span>2</span>
            <h3>Frozen encoder</h3>
            <p>The image backbone is fixed so changes come from the projection objective.</p>
          </article>
          <article data-ours="true">
            <span>3</span>
            <h3>Projection objective</h3>
            <p>Compare external baselines against proposed group, memory, and radius variants.</p>
          </article>
          <article>
            <span>4</span>
            <h3>Held-out retrieval</h3>
            <p>Evaluate Recall@1, MAP@R, and result gain against the best same-backbone prior.</p>
          </article>
        </div>

        <div class="protocol-grid">
          {protocolDatasets.map((dataset) => (
            <article class="protocol-card">
              <h3>{dataset.dataset}</h3>
              <dl>
                <div><dt>Total images</dt><dd>{fmtCount(dataset.examples)}</dd></div>
                <div><dt>Train</dt><dd>{fmtCount(dataset.trainExamples)}</dd></div>
                <div><dt>Held-out test</dt><dd>{fmtCount(dataset.testExamples)}</dd></div>
                <div><dt>Retrieval queries</dt><dd>{fmtCount(dataset.evaluatedQueries)}</dd></div>
              </dl>
            </article>
          ))}
        </div>

        <div class="protocol-band">
          <div>
            <span>Power-study backbones</span>
            <b>{(protocol.backbones ?? []).length}</b>
            <p>{(protocol.backbones ?? []).join(", ")}</p>
          </div>
          <div>
            <span>Objectives</span>
            <b>{protocol.objectiveCount ?? "n/a"}</b>
            <p>External baselines plus proposed group, hybrid, memory, and radius variants.</p>
          </div>
          <div>
            <span>Training</span>
            <b>{protocol.trainSteps ?? "n/a"} steps</b>
            <p>Group size {protocol.groupSize ?? "n/a"}; projection train limit {fmtCount(protocol.projectionTrainLimit)}.</p>
          </div>
        </div>

        <div class="metric-definitions">
          <h3>Metrics used in the report</h3>
          <dl>
            {protocolMetrics.map((metric) => (
              <div>
                <dt>{metric.name}</dt>
                <dd>{metric.definition}</dd>
              </div>
            ))}
          </dl>
        </div>
      </section>

      <section class="section" id="proposal">
        <p class="section-label">Proposed method</p>
        <h2>Architecture of Group SupCon + XBM + Radius</h2>
        <p>
          The method keeps the frozen image encoder fixed and trains only a projection
          head. The novelty is the training signal: grouped SupCon units provide the
          contrastive structure, XBM supplies harder comparisons, and radius control
          keeps neighborhoods compact.
        </p>

        <div class="method-anatomy" data-method-anatomy="true">
          <div class="method-anatomy-heading">
            <div>
              <h3>Interactive method anatomy</h3>
              <p>
                Select a method to see which parts of the training signal are active.
                This makes the difference between SupCon, Group SupCon, and the full
                proposed recipe explicit before the equations.
              </p>
            </div>
            <span>◆ Proposed components are gold-marked</span>
          </div>
          <div class="tab-row">
            {methodAnatomyPanels.map((panel, index) => (
              <button type="button" data-anatomy-tab={panel.key} data-active={index === 3 ? "true" : "false"}>
                {panel.title}
              </button>
            ))}
          </div>
          {methodAnatomyPanels.map((panel, index) => (
            <article class="anatomy-panel" data-anatomy-panel={panel.key} hidden={index !== 3}>
              <div class="anatomy-flow" aria-label={`${panel.title} active components`}>
                {methodAnatomySteps.map((step) => (
                  <div
                    class="anatomy-node"
                    data-step={step.key}
                    data-enabled={panel.enabledStepKeys.includes(step.key) ? "true" : "false"}
                  >
                    <b>{step.label}</b>
                    <span>{step.detail}</span>
                  </div>
                ))}
              </div>
              <div class="anatomy-reading">
                <span>{panel.badge}</span>
                <h4>{panel.title}</h4>
                <p><b>{panel.summary}</b> {panel.reading}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="architecture" data-architecture-explorer="true">
          <h3>Interactive architecture explainer</h3>
          <div class="tab-row">
            {architecturePanels.map((panel, index) => (
              <button type="button" data-architecture-tab={panel.key} data-active={index === 0 ? "true" : "false"}>
                {panel.title}
              </button>
            ))}
          </div>
          {architecturePanels.map((panel, index) => (
            <article class="architecture-panel" data-architecture-panel={panel.key} hidden={index !== 0}>
              <div class="architecture-visual">
                {panel.key === "group" && (
                  <>
                    <span class="box encoder">Frozen image encoder</span>
                    <span class="box head">Projection head</span>
                    <span class="group-bubble one">anchor group</span>
                    <span class="group-bubble two">positive group</span>
                  </>
                )}
                {panel.key === "xbm" && (
                  <>
                    <span class="negative-field">Memory-backed negatives</span>
                    <span class="memory-queue"><i></i><i></i><i></i><i></i><i></i></span>
                  </>
                )}
                {panel.key === "radius" && (
                  <>
                    <span class="radius-ring"></span>
                    <span class="radius-core"></span>
                  </>
                )}
              </div>
              <div class="architecture-copy">
                <h4>{panel.title}</h4>
                <p><b>{panel.summary}</b> {panel.detail}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="contrast-unit-figure" aria-label="SupCon versus Group SupCon contrast units">
          <div class="figure-heading">
            <h3>What changes from SupCon to Group SupCon?</h3>
            <p>
              The visual difference is the contrastive unit. SupCon compares
              individual embeddings. Group SupCon keeps those point comparisons and
              adds normalized same-class group centroids as additional anchors.
            </p>
          </div>
          <div class="contrast-unit-grid">
            <article>
              <h4>SupCon</h4>
              <div class="unit-canvas point-canvas" aria-hidden="true">
                <span class="point anchor"></span>
                <span class="point positive a"></span>
                <span class="point positive b"></span>
                <span class="point negative a"></span>
                <span class="point negative b"></span>
                <span class="link positive-link one"></span>
                <span class="link positive-link two"></span>
                <span class="link negative-link one"></span>
              </div>
              <p><b>Anchor:</b> one example. <b>Positive set:</b> same-class examples.</p>
            </article>
            <article data-ours="true">
              <h4>Group SupCon</h4>
              <div class="unit-canvas group-canvas" aria-hidden="true">
                <span class="cluster left"><i></i><i></i><i></i><b>μg</b></span>
                <span class="cluster right"><i></i><i></i><i></i><b>μp</b></span>
                <span class="cluster negative"><i></i><i></i><i></i><b>μn</b></span>
                <span class="link centroid-link"></span>
                <span class="link centroid-negative"></span>
              </div>
              <p><b>Anchor:</b> normalized group centroid. <b>Positive set:</b> same-class centroids.</p>
            </article>
            <article data-ours="true">
              <h4>Full recipe</h4>
              <div class="unit-stack">
                <span>Point SupCon retained</span>
                <span>Group centroid term added</span>
                <span>XBM hard negatives</span>
                <span>Radius control</span>
              </div>
              <p>The proposed method is the combined recipe, not a centroid-only replacement.</p>
            </article>
          </div>
        </div>

        <div class="equation-explorer" data-equation-explorer="true">
          <h3>SupCon, Group SupCon, and full recipe equations</h3>
          <p>
            These equations show the exact change in training unit. SupCon contrasts
            points. Group SupCon keeps that point term and adds normalized group
            centroids. The full proposed recipe adds memory plus radius control.
          </p>
          <div class="tab-row">
            {equationPanels.map((panel, index) => (
              <button
                type="button"
                data-equation-tab={panel.key}
                data-active={index === 0 ? "true" : "false"}
              >
                {panel.title}
              </button>
            ))}
          </div>
          {equationPanels.map((panel, index) => (
            <article class="equation-panel" data-equation-panel={panel.key} hidden={index !== 0}>
              <div class="equation-copy">
                <h4>{panel.title}</h4>
                <p><b>Training unit:</b> {panel.unit}.</p>
                <p>{panel.explanation}</p>
              </div>
              <div class="equation-card">
                {panel.key === "supcon" && (
                  <>
                    <math display="block" aria-label="Supervised contrastive point loss">
                      <mrow>
                        <msub><mi>L</mi><mtext>SupCon</mtext></msub>
                        <mo>(</mo><mi>i</mi><mo>)</mo><mo>=</mo><mo>-</mo>
                        <mfrac>
                          <mn>1</mn>
                          <mrow><mo>|</mo><mi>P</mi><mo>(</mo><mi>i</mi><mo>)</mo><mo>|</mo></mrow>
                        </mfrac>
                        <munder>
                          <mo>∑</mo>
                          <mrow><mi>p</mi><mo>∈</mo><mi>P</mi><mo>(</mo><mi>i</mi><mo>)</mo></mrow>
                        </munder>
                        <mi>log</mi>
                        <mfrac>
                          <mrow><mi>exp</mi><mo>(</mo><mi>sim</mi><mo>(</mo><msub><mi>z</mi><mi>i</mi></msub><mo>,</mo><msub><mi>z</mi><mi>p</mi></msub><mo>)</mo><mo>/</mo><mi>τ</mi><mo>)</mo></mrow>
                          <mrow><munder><mo>∑</mo><mrow><mi>a</mi><mo>∈</mo><mi>A</mi><mo>(</mo><mi>i</mi><mo>)</mo></mrow></munder><mi>exp</mi><mo>(</mo><mi>sim</mi><mo>(</mo><msub><mi>z</mi><mi>i</mi></msub><mo>,</mo><msub><mi>z</mi><mi>a</mi></msub><mo>)</mo><mo>/</mo><mi>τ</mi><mo>)</mo></mrow>
                        </mfrac>
                      </mrow>
                    </math>
                    <p>Anchor, positives, and comparisons are all individual examples.</p>
                  </>
                )}
                {panel.key === "group" && (
                  <>
                    <math display="block" aria-label="Group centroid">
                      <mrow>
                        <msub><mi>μ</mi><mi>g</mi></msub><mo>=</mo>
                        <mi>normalize</mi>
                        <mo>(</mo>
                        <mfrac>
                          <mn>1</mn>
                          <mrow><mo>|</mo><mi>g</mi><mo>|</mo></mrow>
                        </mfrac>
                        <munder><mo>∑</mo><mrow><mi>j</mi><mo>∈</mo><mi>g</mi></mrow></munder>
                        <msub><mi>z</mi><mi>j</mi></msub>
                        <mo>)</mo>
                      </mrow>
                    </math>
                    <math display="block" aria-label="Group supervised contrastive loss">
                      <mrow>
                        <msub><mi>L</mi><mtext>GroupSupCon</mtext></msub>
                        <mo>=</mo><mi>α</mi>
                        <msub><mi>L</mi><mtext>SupCon</mtext></msub>
                        <mo>(</mo><mi>z</mi><mo>)</mo>
                        <mo>+</mo><mi>γ</mi>
                        <msub><mi>L</mi><mtext>SupCon</mtext></msub>
                        <mo>(</mo><msub><mi>μ</mi><mi>g</mi></msub><mo>)</mo>
                      </mrow>
                    </math>
                    <p>The point term remains; the new term contrasts group centroids.</p>
                  </>
                )}
                {panel.key === "full" && (
                  <>
                    <math display="block" aria-label="Full proposed loss">
                      <mrow>
                        <msub><mi>L</mi><mtext>ours</mtext></msub><mo>=</mo>
                        <msub><mi>L</mi><mtext>GroupSupCon</mtext></msub>
                        <mo>+</mo><mi>β</mi><msub><mi>L</mi><mtext>XBM</mtext></msub>
                        <mo>+</mo><mi>η</mi><msub><mi>L</mi><mtext>hard-group</mtext></msub>
                        <mo>+</mo><msub><mi>λ</mi><mtext>radius</mtext></msub>
                        <mi>R</mi><mo>(</mo><mi>g</mi><mo>)</mo>
                      </mrow>
                    </math>
                    <p>The full recipe extends the Group SupCon core with XBM and radius control.</p>
                  </>
                )}
              </div>
            </article>
          ))}
          <div class="variable-grid" aria-label="Variable legend">
            <h4>Variable legend</h4>
            <dl>
              <div><dt><math><msub><mi>z</mi><mi>i</mi></msub></math></dt><dd>embedding of example i</dd></div>
              <div><dt><math><mi>P</mi><mo>(</mo><mi>i</mi><mo>)</mo></math></dt><dd>same-class positive examples</dd></div>
              <div><dt><math><msub><mi>μ</mi><mi>g</mi></msub></math></dt><dd>normalized centroid of group g</dd></div>
              <div><dt><math><mi>τ</mi></math></dt><dd>contrastive temperature</dd></div>
              <div><dt><math><mi>α</mi><mo>,</mo><mi>γ</mi></math></dt><dd>point and group SupCon weights</dd></div>
              <div><dt>XBM</dt><dd>cross-batch memory queue</dd></div>
              <div><dt><math><mi>η</mi></math></dt><dd>hard group mining weight</dd></div>
              <div><dt><math><msub><mi>λ</mi><mtext>radius</mtext></msub></math></dt><dd>radius regularizer weight</dd></div>
            </dl>
          </div>
        </div>

        <h3>Method catalog</h3>
        <ul class="method-list">
          {methodCatalog.map((method) => (
            <li data-ours={method.isOurs ? "true" : "false"}>
              <div>
                <b>{method.name}</b>
                <span class="tag">{method.origin}</span>
              </div>
              <span>{method.description}</span>
            </li>
          ))}
        </ul>

        <div class="method-matrix">
          <h3>What each method changes</h3>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Method</th>
                  <th>Training unit</th>
                  <th>Mechanism</th>
                  <th>Role in study</th>
                </tr>
              </thead>
              <tbody>
                {methodMatrix.map((method) => (
                  <tr data-ours={method.isOurs ? "true" : "false"}>
                    <td>
                      <b>{method.name}</b>
                      <span class="origin-pill">{method.origin}</span>
                      {method.href && (
