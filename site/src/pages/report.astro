              <article class="result-overview-card">
                <div>
                  <p class="section-label">{row.dataset}</p>
                  <h3>{fmtPercent(row.priorResultGain)}</h3>
                  <span>result gain over best prior</span>
                </div>
                <dl>
                  <div>
                    <dt>Best prior</dt>
