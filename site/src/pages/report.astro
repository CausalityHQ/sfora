                </div>
                <div data-ours="true">
                  <span>2</span>
                  <b>Group SupCon</b>
                  <strong>{fmt(comparison.groupSupcon.mapAtR)}</strong>
                  <small>vs SupCon: {fmtDelta(comparison.groupAdvantage)} MAP@R</small>
                </div>
                <div data-ours="true">
                  <span>3</span>
                  <b>Group SupCon + XBM + Radius</b>
                  <strong>{fmt(comparison.fullRecipe.mapAtR)}</strong>
                  <small>vs SupCon: {fmtDelta(comparison.fullAdvantage)} MAP@R</small>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

