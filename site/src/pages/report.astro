                    <b>{fmt(previous?.mapAtR)}</b>
                  </div>
                  <div class="bar-row ours">
                    <span>Our MAP@R</span>
                    <div class="track"><i style={`--w:${(((row.mapAtR ?? 0) / maxMap) * 100).toFixed(1)}%`}></i></div>
                    <b>{fmt(row.mapAtR)}</b>
