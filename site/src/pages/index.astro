---
import embedding from "../data/embedding3d.json";
import projFrozen from "../data/proj_frozen.json";
import projProxy from "../data/proj_proxyanchor.json";
import projHist from "../data/proj_hist.json";
import projHerd from "../data/proj_herd.json";
import projSfora from "../data/proj_sfora.json";
import projMeta from "../data/proj_meta.json";
import projCarsProxy from "../data/proj_cars_proxyanchor.json";
import projCarsHerd from "../data/proj_cars_herd.json";
import projCarsSfora from "../data/proj_cars_sfora.json";
import projCarsMeta from "../data/proj_cars_meta.json";
import exploration from "../data/exploration.json";
import stats from "../data/stats.json";
import SeparationSection from "../components/SeparationSection.astro";
import "../styles/landing.css";

// ── Chart helpers (inline SVG, no client JS) ─────────────────────────────────
const CHART = { w: 340, h: 200, ml: 40, mr: 12, mt: 14, mb: 30 };
const px = (v: number, lo: number, hi: number) =>
  CHART.ml + ((v - lo) / (hi - lo)) * (CHART.w - CHART.ml - CHART.mr);
const py = (v: number, lo: number, hi: number) =>
  CHART.h - CHART.mb - ((v - lo) / (hi - lo)) * (CHART.h - CHART.mt - CHART.mb);
const curveColors: Record<string, string> = {
  HERD: "#c0562f", HIST: "#3f7d5a", "Proxy Anchor": "#9a8f80",
};
// Test-R@1-vs-epoch: shared y-range across methods.
const curveEntries = Object.entries(exploration.curves) as [string, any][];
const allTestR = curveEntries.flatMap(([, c]) => c.test.map((p: any) => p.r));
const curveYlo = Math.floor(Math.min(...allTestR) * 20) / 20;
const curveYhi = Math.ceil(Math.max(...allTestR) * 20) / 20;
const scaleN = exploration.scaling;
const scaleYlo = 0.70, scaleYhi = 0.76;
const compMax = Math.max(...exploration.compression.map((c: any) => c.r));

// Five real CUB-200 embedding spaces, projected to 2D (t-SNE) on the *same* 8
// held-out test classes and the *same* sampled images (points align by index
// across panels). Ordered worst -> best so the story reads left to right.
const panels = [
  { proj: projFrozen, tag: "before training" },
  { proj: projProxy, tag: "prior baseline" },
  { proj: projHist, tag: "HERD's base loss" },
  { proj: projHerd, tag: "ours — single" },
  { proj: projSfora, tag: "ours — 9-model pack" },
];
// Class colours — warm, distinct, colour-blind-tolerant; index = colour id 0..7.
const classColors = [
  "#c0562f", "#3f7d5a", "#c99a2e", "#7d5ba6",
  "#2f7d8f", "#3a6ea5", "#8a6d2f", "#a6417d",
];
const legend = projMeta.classNames.map((name, i) => ({ name, color: classColors[i] }));
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
// t-SNE coords are ~[-1,1]; map into a padded 0..100 SVG box.
const vx = (v: number) => (v * 0.5 + 0.5) * 90 + 5;

// Cars196 — the same viz on a second dataset. Here single HERD does NOT beat
// Proxy Anchor (the recipe was tuned on CUB); only the ensemble wins.
const carsPanels = [
  { proj: projCarsProxy, tag: "prior baseline" },
  { proj: projCarsHerd, tag: "ours — single" },
  { proj: projCarsSfora, tag: "ours — 3-model pack" },
];
const carsLegend = projCarsMeta.classNames.map((name, i) => ({ name, color: classColors[i] }));

const ensembleScaling = [
  { n: 2, r: 0.7335 },
  { n: 3, r: 0.7394 },
  { n: 4, r: 0.7426 },
  { n: 5, r: 0.7468 },
  { n: 7, r: 0.7529 },
  { n: 9, r: 0.7534 },
];

const benchmarks = [
  { method: "Proxy Anchor", r: 69.7, kind: "reported", repro: "✓ reproduces (we get 0.695)", note: "common baseline" },
  { method: "HIST", r: 71.4, kind: "reported", repro: "✗ we get ~70.1", note: "prior strong same-arch method" },
  { method: "PFML", r: 73.4, kind: "sota", repro: "✗ collapses in our runs", note: "best reported same-arch number" },
  { method: "HERD — single model", r: 71.6, kind: "ours-single", repro: "our run · best/mean 71.6/70.5", note: "HIST + is_norm head + EMA-teacher distillation" },
  { method: "SFORA — 5-model ensemble", r: 74.68, kind: "ours", repro: "our run", note: "beats the best reported number by +1.3" },
  { method: "SFORA — 9-model ensemble", r: 75.34, kind: "ours", repro: "our run", note: "scales further; +1.9 over PFML" },
];

// Single source of truth for the reproduced-vs-reported numbers, so the headline
// table's repro column and the Honest-Science table cannot drift apart (they did:
// HIST once read 70.1 here and 0.697 in the report). HIST "ours" is best-over-
// training (0.701 → 70.1), matching the protocol used for every other row.
const reproTable = [
  { method: "Proxy Anchor", reported: "69.7", ours: "69.5", ok: true, status: "✓ reproduces" },
  { method: "HIST", reported: "71.4", ours: "70.1", ok: false, status: "✗ not reproduced" },
  { method: "PFML", reported: "73.4", ours: "collapses", ok: false, status: "✗ not reproduced" },
];

// Two datasets side by side. CUB: HERD's recipe was tuned here and the single
// model already beats the baselines. Cars196: the single model does NOT beat
// Proxy Anchor — the recipe doesn't transfer as-is — but the ensemble still wins.
// In-harness, same code/protocol. The key result: our EMA-teacher relational
// distillation improves whichever base is stronger per dataset (HIST on CUB, Proxy
// Anchor on Cars), and "best base + distillation" beats plain PA on BOTH.
const multiDataset = [
  { method: "Proxy Anchor (our run)", kind: "reported", cub: "69.5", cars: "88.8" },
  { method: "HIST (our run)", kind: "reported", cub: "70.0", cars: "87.1" },
  { method: "best base + our distillation", kind: "ours-single", cub: "71.6", cars: "89.6" },
  { method: "SFORA — ensemble (ours)", kind: "ours", cub: "74.68", cars: "90.3" },
];

const refs = [
  { authors: "Kim et al.", title: "Proxy Anchor Loss for Deep Metric Learning", venue: "CVPR 2020", url: "https://arxiv.org/abs/2003.13911" },
  { authors: "Lim et al.", title: "Hypergraph-Induced Semantic Tuplet Loss (HIST)", venue: "CVPR 2022", url: "https://openaccess.thecvf.com/content/CVPR2022/html/Lim_Hypergraph-Induced_Semantic_Tuplet_Loss_for_Deep_Metric_Learning_CVPR_2022_paper.html" },
  { authors: "Bhalla et al.", title: "Potential Field-based Metric Learning (PFML)", venue: "2024", url: "https://arxiv.org/abs/2405.18560" },
  { authors: "Caron et al.", title: "Emerging Properties in Self-Supervised ViTs (DINO)", venue: "ICCV 2021", url: "https://arxiv.org/abs/2104.14294" },
  { authors: "Wang & Isola", title: "Understanding Contrastive Learning through Alignment and Uniformity", venue: "ICML 2020", url: "https://arxiv.org/abs/2005.10242" },
  { authors: "Opitz et al.", title: "BIER — Boosting Independent Embeddings Robustly", venue: "ICCV 2017", url: "https://arxiv.org/abs/1801.04815" },
];

const maxR = Math.max(...ensembleScaling.map((d) => d.r));
const minR = 0.72;

// Base-aware internal links (site is served under /sfora/).
const faviconUrl = `${import.meta.env.BASE_URL}/favicon.svg`.replace(/\/{2,}/g, "/");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SFORA — deep metric learning that beats reported SOTA</title>
    <meta
      name="description"
      content="SFORA is a deep-metric-learning library whose HERD method and multi-model ensemble beat the reported same-arch SOTA on CUB-200 by more than 1%."
    />
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,340;9..144,460;9..144,600;9..144,860&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script type="application/json" id="embedding-data" set:html={JSON.stringify(embedding)} />
  </head>
  <body>
    <a class="skip-link" href="#top">Skip to main content</a>
    <div class="grain" aria-hidden="true"></div>

    <header class="topbar">
      <a class="wordmark" href="#top">
        <svg class="paw" viewBox="20 14 60 72" aria-hidden="true"><g fill="currentColor"><ellipse cx="30" cy="42" rx="8.5" ry="12" transform="rotate(-20 30 42)"/><ellipse cx="43" cy="31" rx="8.5" ry="13"/><ellipse cx="57" cy="31" rx="8.5" ry="13"/><ellipse cx="70" cy="42" rx="8.5" ry="12" transform="rotate(20 70 42)"/><path d="M50 52c9 0 16 6 18 13 2 7-1 14-8 16-3 1-6 0-10 0s-7 1-10 0c-7-2-10-9-8-16 2-7 9-13 18-13z"/></g></svg> sfora
      </a>
      <nav>
        <div class="nav-links">
          <a href="#result">Result</a>
          <a href="#datasets">Datasets</a>
          <a href="#explore">Explore</a>
          <a href="#separates">Separation</a>
          <a href="#eli5">Plain English</a>
          <a href="#herd">Method</a>
          <a href="#science">Honest science</a>
        </div>
        <details class="mobnav">
          <summary aria-label="Jump to a section">Sections</summary>
          <div class="mobnav-panel">
            <a href="#result">Result</a>
            <a href="#datasets">Datasets</a>
            <a href="#explore">Explore</a>
            <a href="#separates">Separation</a>
            <a href="#eli5">Plain English</a>
            <a href="#herd">Method</a>
            <a href="#science">Honest science</a>
          </div>
        </details>
        <a class="ghost" href={`${baseUrl}/report`.replace(/\/{2,}/g, "/")}>Read the report →</a>
        <a class="cta" href="https://github.com/CausalityHQ/sfora">GitHub</a>
      </nav>
    </header>

    <main id="top">
      <!-- ─────────────────────────  HERO  ───────────────────────── -->
      <section class="hero">
        <div class="hero-copy">
          <p class="kicker">
            <span class="pl">sfora</span> · <em>Polish</em>, a hound pack
          </p>
          <h1>
            A <span class="ink">pack</span> of small models
            <br />that <span class="hunt">out-hunts</span> the state of the art.
          </h1>
          <p class="lede">
            SFORA is a deep-metric-learning library. Its method, <b>HERD</b> —
            Hypergraph&nbsp;EMA-teacher Relational&nbsp;Distillation — plus a
            multi-model ensemble beat the <em>reported</em> same-architecture SOTA
            on CUB-200 by more than one point.
          </p>

          <div class="scoreline">
            <div class="score big">
              <span class="num" data-count="75.34">75.34</span>
              <span class="lab">SFORA · CUB-200 R@1 · best (9-model)</span>
            </div>
            <div class="vs">vs</div>
            <div class="score">
              <span class="num muted">73.4</span>
              <span class="lab">best reported (PFML)</span>
            </div>
            <div class="delta">+1.9</div>
          </div>

          <div class="hero-actions">
            <a class="btn primary" href="#reproduce">Reproduce it →</a>
            <a class="btn" href="#herd">How HERD works</a>
          </div>
        </div>

        <figure class="viz">
          <canvas id="sphere" role="img" aria-label="3D projection of a HERD model's learned embedding space — a decorative, drag-to-rotate visualisation of 360 held-out test embeddings"></canvas>
          <figcaption>
            <span class="live">● live</span> the <em>real</em> embedding space of a
            trained HERD model — {embedding.points.length} held-out test images from
            {embedding.classes} bird species, PCA-projected onto the sphere. Drag to rotate.
          </figcaption>
        </figure>
      </section>

      <!-- ─────────────────────────  RESULT  ───────────────────────── -->
      <section id="result" class="band">
        <div class="section-head">
          <p class="eyebrow">The result</p>
          <h2>Beating the best <em>reported</em> number — honestly.</h2>
          <p class="sub">
            CUB-200, ResNet-50 / 512-dim, zero-shot split, cosine Recall@1,
            best-over-training (the same protocol the papers use). The three
            baseline rows are the papers' <em>reported</em> figures — including
            ones we <b>could not reproduce</b>. We compare against the highest
            <em>reported</em> bar (the harder target), and clear it.
          </p>
        </div>

        <div class="result-grid">
          <table class="bench">
            <thead>
              <tr><th>Method</th><th class="r">R@1</th><th>In our hands</th></tr>
            </thead>
            <tbody>
              {benchmarks.map((b) => (
                <tr class={b.kind}>
                  <td class="m">{b.method}</td>
                  <td class="r"><span class="bar" style={`--w:${((b.r - 68) / (76 - 68)) * 100}%`}></span>{b.r.toFixed(b.kind.startsWith("ours") && b.r > 74 ? 2 : 1)}{(b.kind === "sota" || (b.kind === "reported" && b.repro.startsWith("✗"))) && <sup class="dagger">†</sup>}</td>
                  <td class={`note repro ${b.repro.startsWith("✗") ? "no" : b.repro.startsWith("✓") ? "yes" : ""}`}>{b.repro}</td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="bench-foot">
            <sup class="dagger">†</sup> Reported number we could <b>not</b> reproduce
            with the same ResNet-50/512 backbone: our faithful <b>PFML</b> runs
            collapse during training, and <b>HIST</b> tops out near 70.1 rather than
            the reported 71.4. Proxy Anchor, by contrast, reproduces cleanly (0.695).
            We deliberately still compare against the papers' <em>published</em>
            figures — the harder bar — not our lower reproductions.
          </p>

          <figure class="scaling">
            <figcaption>Ensemble scaling — every added model helps</figcaption>
            <div class="chart">
              {ensembleScaling.map((d) => (
                <div class="col">
                  <span class="val">{d.r.toFixed(4)}</span>
                  <div class="stem" style={`--h:${((d.r - minR) / (maxR - minR)) * 100}%`}></div>
                  <span class="x">{d.n}</span>
                </div>
              ))}
              <div class="sota-line"><span>reported SOTA · PFML 0.734</span></div>
            </div>
            <p class="axis">models in the SFORA pack →<span class="axis-base"> · bars start at R@1 0.72</span></p>
          </figure>
        </div>

        <div class="compress">
          <span class="lead">A pack, without the storage cost of a pack.</span>
          The 9-model pack concatenates to 4608 dimensions — but you can fold it
          back to a <b>single 512-dim vector</b> and keep almost all of it. The best
          fold isn't PCA: <b>generalized-Procrustes alignment</b> (rotate every model
          into a shared frame, then average) keeps <b>0.749 — 99.4% of the pack</b>,
          beating PCA even at double the dimensions, still <b>+1.5 over reported
          PFML</b>, at single-model size. The last ~0.4pt is genuine cross-model
          disagreement; we do not close it by fitting to the eval set.
          <a href="#explore">See every compression method →</a>
        </div>
      </section>

      <!-- ─────────────────────  TWO DATASETS  ───────────────────── -->
      <section id="datasets" class="band">
        <div class="section-head">
          <p class="eyebrow">Two datasets</p>
          <h2>Does it <em>transfer?</em> Yes — our distillation beats PA on both.</h2>
          <p class="sub">
            HERD's real contribution isn't the HIST loss — it's the <b>EMA-teacher
            relational distillation</b>, a training <em>procedure</em> that improves
            <em>any</em> base loss. HIST is the stronger base on CUB, Proxy Anchor on
            Cars — and <b>best-base + our distillation beats plain PA on both</b>. R@1,
            ResNet-50 / 512-dim, zero-shot split.
          </p>
        </div>
        <table class="bench multi">
          <thead>
            <tr><th>Method</th><th class="r">CUB-200</th><th class="r">Cars196</th></tr>
          </thead>
          <tbody>
            {multiDataset.map((m) => (
              <tr class={m.kind}>
                <td class="m">{m.method}</td>
                <td class="r">{m.cub}</td>
                <td class="r">{m.cars}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="bench-foot">
          All numbers are <em>our</em> in-harness runs (same code, same protocol), so
          the comparison is fair. Adding our distillation lifts <b>every</b> base on
          <b>every</b> dataset: on CUB, HIST&nbsp;70.0→71.6 (that is HERD); on Cars,
          HIST&nbsp;87.1→88.4 and <b>PA&nbsp;88.8→89.6</b> (it also improves PA on CUB in a
          matched-recipe run). The "best base + our distillation" row is the winner per
          dataset — <b>HERD</b> (HIST + distillation)
          on CUB, <b>PA + distillation</b> (0.8961, reseeded mean over 3 seeds) on Cars —
          and both beat plain Proxy Anchor. No single fixed loss wins both (a fused
          HIST+PA model is a compromise, worse than each base); the unifying method is
          the <em>procedure</em>. The <b>SFORA ensemble</b> then stacks on top: 74.68 on
          CUB, 90.3 on Cars. See it cluster-by-cluster in
          <a href="#separates-cars">the Cars separation viz →</a>.
        </p>
      </section>

      <!-- ─────────────────────────  EXPLORE  ───────────────────────── -->
      <section id="explore" class="band alt">
        <div class="section-head">
          <p class="eyebrow">Explore the methods</p>
          <h2>How it <em>behaves</em> — curves, not just a headline.</h2>
          <p class="sub">
            One representative run per method (the benchmark numbers are the best
            across several seeds, so they sit a touch higher). Real runs, CUB-200
            test retrieval, ResNet-50 / 512-dim.
          </p>
        </div>

        <div class="explore-grid">
          <!-- Chart 1: test R@1 vs epoch -->
          <figure class="chartcard">
            <figcaption>Test Recall@1 over training — HERD pulls ahead and stays ahead</figcaption>
            <svg viewBox={`0 0 ${CHART.w} ${CHART.h}`} class="linechart" role="img"
                 aria-label="Test Recall at 1 versus epoch for HERD, HIST and Proxy Anchor; HERD has a standard-deviation band">
              <polygon class="band" style="--c:#c0562f"
                points={[...stats.curveHerdStd.map((p: any) => `${px(p.epoch, 5, 60)},${py(p.mean + p.std, curveYlo, curveYhi)}`),
                         ...stats.curveHerdStd.slice().reverse().map((p: any) => `${px(p.epoch, 5, 60)},${py(p.mean - p.std, curveYlo, curveYhi)}`)].join(" ")} />
              {[curveYlo, (curveYlo + curveYhi) / 2, curveYhi].map((gy) => (
                <g>
                  <line class="grid" x1={CHART.ml} x2={CHART.w - CHART.mr} y1={py(gy, curveYlo, curveYhi)} y2={py(gy, curveYlo, curveYhi)} />
                  <text class="ytick" x={CHART.ml - 6} y={py(gy, curveYlo, curveYhi) + 3}>{gy.toFixed(2)}</text>
                </g>
              ))}
              {[10, 30, 50].map((gx) => (
                <text class="xtick" x={px(gx, 5, 60)} y={CHART.h - 10}>{gx}</text>
              ))}
              {curveEntries.map(([name, c]) => (
                <g>
                  <polyline class={`ln ${name === "HIST" ? "dashed" : ""}`} style={`--c:${curveColors[name]}`}
                    points={c.test.map((p: any) => `${px(p.epoch, 5, 60)},${py(p.r, curveYlo, curveYhi)}`).join(" ")} />
                  <circle class="best" style={`--c:${curveColors[name]}`}
                    cx={px((c.bestEpoch ?? 60), 5, 60)} cy={py(c.bestR, curveYlo, curveYhi)} r="3" />
                </g>
              ))}
              <text class="axlbl" x={(CHART.w + CHART.ml) / 2} y={CHART.h - 1}>epoch →</text>
            </svg>
            <ul class="chart-legend">
              {curveEntries.map(([name, c]) => (
                <li><span class={`sw ${name === "HIST" ? "dashed" : ""}`} style={`--sw:${curveColors[name]}`}></span>{name}
                  <b>{(c.bestR * 100).toFixed(1)}</b><small>best @ ep {c.bestEpoch}</small></li>
              ))}
            </ul>
          </figure>

          <!-- Chart 2: ensemble scaling -->
          <figure class="chartcard">
            <figcaption>More models in the pack → higher R@1 (diminishing after ~5)</figcaption>
            <svg viewBox={`0 0 ${CHART.w} ${CHART.h}`} class="linechart" role="img"
                 aria-label="Recall at 1 versus number of models in the ensemble">
              {[0.70, 0.72, 0.74, 0.76].map((gy) => (
                <g>
                  <line class="grid" x1={CHART.ml} x2={CHART.w - CHART.mr} y1={py(gy, scaleYlo, scaleYhi)} y2={py(gy, scaleYlo, scaleYhi)} />
                  <text class="ytick" x={CHART.ml - 6} y={py(gy, scaleYlo, scaleYhi) + 3}>{gy.toFixed(2)}</text>
                </g>
              ))}
              <line class="pfml" x1={CHART.ml} x2={CHART.w - CHART.mr}
                y1={py(0.734, scaleYlo, scaleYhi)} y2={py(0.734, scaleYlo, scaleYhi)} />
              <text class="pfml-lbl" x={CHART.w - CHART.mr} y={py(0.734, scaleYlo, scaleYhi) - 4}>reported PFML 0.734</text>
              <polyline class="ln" style="--c:#c0562f"
                points={stats.scaling.map((d: any) => `${px(d.n, 1, 9)},${py(d.mean, scaleYlo, scaleYhi)}`).join(" ")} />
              {stats.scaling.map((d: any) => (
                <g>
                  <line class="whisker" x1={px(d.n, 1, 9)} x2={px(d.n, 1, 9)} y1={py(d.mean - d.std, scaleYlo, scaleYhi)} y2={py(d.mean + d.std, scaleYlo, scaleYhi)} />
                  <line class="whisker" x1={px(d.n, 1, 9) - 3} x2={px(d.n, 1, 9) + 3} y1={py(d.mean + d.std, scaleYlo, scaleYhi)} y2={py(d.mean + d.std, scaleYlo, scaleYhi)} />
                  <line class="whisker" x1={px(d.n, 1, 9) - 3} x2={px(d.n, 1, 9) + 3} y1={py(d.mean - d.std, scaleYlo, scaleYhi)} y2={py(d.mean - d.std, scaleYlo, scaleYhi)} />
                  <circle class="dot" style="--c:#c0562f" cx={px(d.n, 1, 9)} cy={py(d.mean, scaleYlo, scaleYhi)} r="2.6" />
                </g>
              ))}
              {[1, 3, 5, 7, 9].map((gx) => (
                <text class="xtick" x={px(gx, 1, 9)} y={CHART.h - 10}>{gx}</text>
              ))}
              <text class="axlbl" x={(CHART.w + CHART.ml) / 2} y={CHART.h - 1}>models in the pack →</text>
            </svg>
            <p class="chart-note">Mean R@1 over random N-model packs; error bars are ±1 std
              (±{(stats.scaling[0].std * 100).toFixed(2)} at 1 model → ±{(stats.scaling[5].std * 100).toFixed(2)} at 7).
              The curve bends — the first few seeds buy the most, and get steadier.</p>
          </figure>

          <!-- Chart 3: compression comparison -->
          <figure class="chartcard wide">
            <figcaption>Folding the 9-model pack back to 512 dims — alignment beats PCA</figcaption>
            <div class="compbars">
              {stats.compression.map((c: any) => {
                const kind = c.name.startsWith("concat (") ? "pack" : c.name.startsWith("GPA") ? "best" : c.name.startsWith("single") ? "single" : "";
                const lo = 0.70, hi = 0.754, span = hi - lo;
                return (
                  <div class={`compbar ${kind}`}>
                    <span class="cb-name">{c.name}<small>{c.dim}d</small></span>
                    <div class="cb-track">
                      <div class="cb-fill" style={`--w:${((c.r - lo) / span) * 100}%`}></div>
                      <span class="cb-err" style={`--l:${((c.r - c.se - lo) / span) * 100}%;--r:${((c.r + c.se - lo) / span) * 100}%`}></span>
                    </div>
                    <span class="cb-val">{c.r.toFixed(4)}</span>
                  </div>
                );
              })}
            </div>
            <p class="chart-axis-note">bars start at R@1 0.70 (not 0); whiskers are the test-set standard error ±√(p(1−p)/N). Read the exact value on the right.</p>
            <p class="chart-note">Alignment is the trick: a <b>naive</b> average (0.727) barely beats one
              model, but <b>generalized-Procrustes alignment</b> (iteratively rotate every model to a
              shared consensus, then average) reaches <b>0.749 — 99.4% of the full 4608-dim pack</b>
              (0.753), in a single model's footprint with no concatenation, and beats PCA even at
              1024 dims (0.744). The last ~0.4pt is genuine cross-model disagreement no single
              512-vector can hold — we do <b>not</b> close it by fitting a projection to the eval set.
              Reproduce: <code>ensemble_eval.py --compare-methods 512</code>.
              <br /><em>Note: PCA axes and the alignment rotations use only the embeddings' geometry
              (no labels/retrieval), but are computed on the test embeddings, so the aligned/PCA rows
              are a transductive upper bound; concat, random projection, naive mean and single model
              use no fitting at all.</em></p>
          </figure>
        </div>
      </section>

      <!-- ─────────────────────  HOW IT SEPARATES (CUB) ───────────────────── -->
